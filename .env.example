APP_NAME=Perpustakaan
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/

# IMPORTANT for cross-origin FE<->BE: SESSION_DOMAIN must be EMPTY (null).
# Setting it to "localhost" or any other value will scope the cookie to that
# domain, which blocks the browser from sending the cookie back to a BE on a
# different domain (e.g. apsi-perpustakaan-be-production.up.railway.app).
# Leave unset / null in production.
SESSION_DOMAIN=null

# HTTP-only cookies always (XSS hardening).
SESSION_HTTP_ONLY=true

# SameSite: "lax" is the safest cross-origin default for Sanctum SPA flow.
# Use "none" only together with SESSION_SECURE_COOKIE=true (HTTPS-only).
SESSION_SAME_SITE=lax

# Force secure cookie flag in production (HTTPS-only BE).
# When false, the browser still sends the cookie over HTTP, but Sanctum SPA
# requires HTTPS in production. Set to true on Railway / any TLS-terminated BE.
SESSION_SECURE_COOKIE=false

# CSRF / Sanctum SPA: list every FE origin that is allowed to authenticate.
# Comma-separated. NO wildcard (*) — Sanctum does literal match, and the
# Origin header must be present.
SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173

# Frontend URL used by CORS / email / asset URL generation.
FRONTEND_URL=http://localhost:5173

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION (Railway / any HTTPS BE with cross-origin FE)
# ─────────────────────────────────────────────────────────────────────────────
# Copy the block below into Railway "Variables" tab. Do NOT commit a real
# .env.production with secrets — Railway injects these as runtime env vars.
#
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://apsi-perpustakaan-be-production.up.railway.app
# APP_KEY=base64:<generate with: php artisan key:generate --show>
# LOG_CHANNEL=stderr
# LOG_LEVEL=info
#
# DB_CONNECTION=mysql
# DB_HOST=${{MySQL.MYSQLHOST}}
# DB_PORT=${{MySQL.MYSQLPORT}}
# DB_DATABASE=${{MySQL.MYSQLDATABASE}}
# DB_USERNAME=${{MySQL.MYSQLUSER}}
# DB_PASSWORD=${{MySQL.MYSQLPASSWORD}}
#
# SESSION_DOMAIN=                                          ← MUST be empty
# SESSION_SECURE_COOKIE=true                               ← HTTPS-only
# SESSION_SAME_SITE=lax
# SESSION_DRIVER=database
#
# SANCTUM_STATEFUL_DOMAINS=apsi-perpustakaan-fe-production.up.railway.app,localhost:5173,127.0.0.1:5173
#
# FRONTEND_URL=https://apsi-perpustakaan-fe-production.up.railway.app
# CACHE_STORE=database
# QUEUE_CONNECTION=database
